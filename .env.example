DATABASE_URL=postgresql+asyncpg://motiontracker:motiontracker@localhost:5433/motiontracker

HA_URL=http://192.168.1.XXX:8123
HA_TOKEN=your_long_lived_access_token_here
# Format: person.name:sensor.activity_entity,person.name2:sensor.activity_entity2
# Activity sensor (after colon) is optional — omit or leave empty to skip activity classification
HA_TRACKED_ENTITIES=device_tracker.person1_iphone:sensor.person1_activity,device_tracker.person2_iphone:sensor.person2_activity

POLL_INTERVAL_SECONDS=300
QUIET_HOURS_START=23
QUIET_HOURS_END=6
QUIET_HOURS_ENABLED=true

BACKFILL_ON_STARTUP=true
BACKFILL_DAYS=7
# Periodic catch-up backfill: runs every BACKFILL_INTERVAL_HOURS to fetch HA state changes
# that polling missed (e.g. intermediate GPS updates between 5-min poll cycles)
BACKFILL_INTERVAL_HOURS=1
BACKFILL_CATCHUP_HOURS=2

# Minimum movement in metres before a polled point is stored.
# 0 = store every poll (matches backfill resolution, ~288 rows/day when stationary)
# 20 = old behaviour (skip stationary points)
MIN_MOVEMENT_METERS=0

# Stadia Maps API key — required for non-localhost deployments
# Get a free key at https://client.stadiamaps.com and allowlist your domain
STADIA_API_KEY=

LOG_LEVEL=INFO
TZ=Europe/Stockholm
