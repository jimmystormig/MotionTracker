# Seal this with: kubeseal --format yaml < this-file.yaml > motiontracker-env.sealed.yaml
apiVersion: v1
kind: Secret
metadata:
  name: motiontracker-env
  labels:
    app.kubernetes.io/part-of: motiontracker
type: Opaque
stringData:
  DATABASE_URL: "postgresql+asyncpg://motiontracker:@motiontracker-db-rw.default.svc.cluster.local:5432/motiontracker"
  HA_URL: "http://homeassistant-service.default.svc.cluster.local"
  HA_TOKEN: "CHANGE_ME_HA_LONG_LIVED_TOKEN"
  # Format: person.name:sensor.activity_entity,person.name2: (activity sensor optional)
  HA_TRACKED_ENTITIES: "device_tracker.person1_iphone:sensor.person1_activity,device_tracker.person2_iphone:sensor.person2_activity"
  POLL_INTERVAL_SECONDS: "300"
  QUIET_HOURS_START: "23"
  QUIET_HOURS_END: "6"
  QUIET_HOURS_ENABLED: "true"
  BACKFILL_ON_STARTUP: "true"
  BACKFILL_DAYS: "7"
  STADIA_API_KEY: ""
  LOG_LEVEL: "INFO"
  TZ: "Europe/Stockholm"
